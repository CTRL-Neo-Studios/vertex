{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Vertex",
  "version": "0.1.0",
  "identifier": "dev.ctrl-neo.vertex",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Vertex",
        "width": 900,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 21
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist"
    },
    "fileAssociations": [
      {
        "ext": [
          "md"
        ],
        "mimeType": "text/markdown",
        "name": "Markdown",
        "description": "The Markdown Format",
        "role": "Editor"
      },
      {
        "ext": [
          "txt"
        ],
        "mimeType": "text/plain",
        "name": "Text",
        "description": "The Plain Text Format",
        "role": "Editor"
      }
    ]
  }
}
